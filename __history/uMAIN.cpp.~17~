TForm1 *Form1;
string File;
string Path;
string zipPath;

void unzipDOCX(string file) {
	system(("cd " + Path + " && mkdir temp && cd temp && tar -xf " + File).c_str());
}

void CryptFile(filesystem::path file) {
    string temp_file_path = file.parent_path().string() + "\\temp.jpeg";
	ifstream file1(file.string(), ios::binary);
	ofstream file2(temp_file_path, ios::binary);
}

